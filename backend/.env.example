# Environment Configuration for Scrollix

# Port to run the server on (default: 3000)
PORT=3000

# Base URL of the application. 
# In production, this should be set to your live domain (e.g. https://scrollix.in).
# Note: If deployed on Railway, the app will automatically default to https://scrollix.in 
# if this is not explicitly provided.
BASE_URL=http://localhost:3000

# Secret key used for signing JWT tokens for the admin panel. 
# Change this to a long random string in production!
JWT_SECRET=super_secret_production_key_here

# Path to the SQLite database file. 
# On Railway or other cloud platforms, you should set this to a mounted persistent volume 
# path (e.g. /data/scrollix.db) so you don't lose data on redeploys.
DB_PATH=./scrollix.db
